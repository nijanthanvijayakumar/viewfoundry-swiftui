{
  "name": "@viewfoundry/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal TypeScript runtime skeleton for ViewFoundry SwiftUI.",
  "bin": {
    "viewfoundry": "./dist/src/cli.js",
    "viewfoundry-diff": "./dist/src/diff-cli.js",
    "viewfoundry-mockup": "./dist/src/mockup-cli.js"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run test:unit",
    "test:unit": "npm run build && node --test \"dist/tests/**/*.test.js\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "pngjs": "^7.0.0"
  }
}
